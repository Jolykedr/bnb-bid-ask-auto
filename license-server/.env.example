# License Server Configuration
# Copy to .env and fill in values

# Admin secret for API endpoints (generate: python -c "import secrets; print(secrets.token_urlsafe(32))")
LICENSE_ADMIN_SECRET=CHANGE_ME_TO_RANDOM_STRING

# Server port
LICENSE_PORT=8443

# Database (default: sqlite in current directory)
# LICENSE_DB_URL=sqlite:///licenses.db

# SSL certificate paths (generated by setup_ssl.sh)
# SSL_CERT_FILE=certs/server.crt
# SSL_KEY_FILE=certs/server.key
